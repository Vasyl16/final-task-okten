# Copy to .env.local (or .env) for local development.

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# Google Sign-In — MUST use the VITE_ prefix or Vite will not expose it to the app (button stays hidden).
# Same value as backend GOOGLE_CLIENT_ID (Web client from Google Cloud Console).
# Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
