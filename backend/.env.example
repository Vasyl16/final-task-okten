# Copy to .env and fill in real values.

NODE_ENV=development
PORT=3000

# Allowed browser origin for CORS (your Vite dev server or production URL)
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# JWT — use long random strings in production (min 32 chars each)
JWT_SECRET=replace-with-at-least-32-character-secret-for-access-token
JWT_REFRESH_SECRET=replace-with-at-least-32-character-secret-for-refresh-token
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (image uploads + seed)
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your-access-key-id
AWS_SECRET_KEY=your-secret-access-key
# Public base URL for objects (no trailing slash issues — app normalizes)
AWS_ENDPOINT=https://your-bucket.s3.your-region.amazonaws.com

# Google Sign-In — Web client ID from Google Cloud Console (OAuth 2.0 Client IDs)
# Must match the client used on the frontend (same as VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

SMTP_EMAIL="your-smtp-email"
SMTP_PASSWORD=your-smtp-password
